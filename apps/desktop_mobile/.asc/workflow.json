{
  "env": {
    "ASC_BYPASS_KEYCHAIN": "1",
    "ASC_BIN": "../../tools/bin/asc",
    "APP_ID": "SET_APP_STORE_CONNECT_APP_ID",
    "PROJECT_PATH": "ios/Runner.xcodeproj",
    "WORKSPACE_PATH": "ios/Runner.xcworkspace",
    "SCHEME": "Runner",
    "CONFIGURATION": "Release",
    "EXPORT_OPTIONS": ".asc/export-options-app-store.plist",
    "TESTFLIGHT_GROUP": "Internal Testing",
    "VERSION": ""
  },
  "workflows": {
    "testflight_beta": {
      "description": "Build the Flutter iOS app, export an IPA, upload to App Store Connect, and attach it to a TestFlight group.",
      "steps": [
        {
          "name": "validate_inputs",
          "run": "if [ -z \"$VERSION\" ]; then echo \"VERSION is required, for example VERSION:1.0.0\" >&2; exit 1; fi; if [ \"$APP_ID\" = \"SET_APP_STORE_CONNECT_APP_ID\" ]; then echo \"Set APP_ID in .asc/workflow.json or pass APP_ID:<id>\" >&2; exit 1; fi; if [ ! -f \"$EXPORT_OPTIONS\" ]; then echo \"Create $EXPORT_OPTIONS from .asc/export-options-app-store.plist.example\" >&2; exit 1; fi"
        },
        {
          "name": "resolve_next_build",
          "run": "\"$ASC_BIN\" builds latest --app \"$APP_ID\" --version \"$VERSION\" --platform IOS --next --initial-build-number 1 --output json",
          "outputs": {
            "BUILD_NUMBER": "$.nextBuildNumber"
          }
        },
        {
          "name": "flutter_prepare",
          "run": "flutter pub get && flutter build ios --release --config-only --build-name \"$VERSION\" --build-number \"${steps.resolve_next_build.BUILD_NUMBER}\" --no-codesign"
        },
        {
          "name": "archive",
          "run": "\"$ASC_BIN\" xcode archive --workspace \"$WORKSPACE_PATH\" --scheme \"$SCHEME\" --configuration \"$CONFIGURATION\" --archive-path \".asc/artifacts/Actions-$VERSION-${steps.resolve_next_build.BUILD_NUMBER}.xcarchive\" --clean --overwrite --xcodebuild-flag=-destination --xcodebuild-flag=generic/platform=iOS --xcodebuild-flag=-allowProvisioningUpdates --xcodebuild-flag=FLUTTER_BUILD_NAME=$VERSION --xcodebuild-flag=FLUTTER_BUILD_NUMBER=${steps.resolve_next_build.BUILD_NUMBER} --xcodebuild-flag=MARKETING_VERSION=$VERSION --xcodebuild-flag=CURRENT_PROJECT_VERSION=${steps.resolve_next_build.BUILD_NUMBER} --output json",
          "outputs": {
            "ARCHIVE_PATH": "$.archive_path",
            "VERSION": "$.version",
            "BUILD_NUMBER": "$.build_number"
          }
        },
        {
          "name": "export",
          "run": "\"$ASC_BIN\" xcode export --archive-path ${steps.archive.ARCHIVE_PATH} --export-options \"$EXPORT_OPTIONS\" --ipa-path \".asc/artifacts/Actions-$VERSION-${steps.archive.BUILD_NUMBER}.ipa\" --overwrite --xcodebuild-flag=-allowProvisioningUpdates --output json",
          "outputs": {
            "IPA_PATH": "$.ipa_path",
            "VERSION": "$.version",
            "BUILD_NUMBER": "$.build_number"
          }
        },
        {
          "name": "publish",
          "run": "\"$ASC_BIN\" publish testflight --app \"$APP_ID\" --ipa ${steps.export.IPA_PATH} --group \"$TESTFLIGHT_GROUP\" --wait --poll-interval 30s --output json",
          "outputs": {
            "BUILD_ID": "$.buildId",
            "BUILD_NUMBER": "$.buildNumber"
          }
        }
      ]
    }
  }
}
