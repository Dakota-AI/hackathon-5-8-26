# Optional local Amplify Auth values for the web app.
# These are not secrets, but real environment-specific outputs should stay local/CI-managed.
NEXT_PUBLIC_AMPLIFY_REGION=us-east-1
NEXT_PUBLIC_AMPLIFY_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_AMPLIFY_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_AMPLIFY_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Future Control API endpoint once ControlApiStack exists.
NEXT_PUBLIC_AGENTS_CLOUD_API_URL=
