{
  "name": "agents-cloud",
  "private": true,
  "version": "0.0.0",
  "description": "Autonomous AI agent cloud platform foundation workspace.",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "contracts:build": "pnpm --filter @agents-cloud/protocol run build",
    "contracts:test": "pnpm --filter @agents-cloud/protocol test",
    "agent-profile:build": "pnpm --filter @agents-cloud/agent-profile run build",
    "agent-profile:test": "pnpm --filter @agents-cloud/agent-profile run test",
    "schemas:validate": "pnpm --filter @agents-cloud/protocol validate",
    "control-api:build": "pnpm contracts:build && pnpm --filter @agents-cloud/control-api run build",
    "control-api:test": "pnpm --filter @agents-cloud/control-api run test",
    "agent-runtime:build": "pnpm contracts:build && pnpm --filter @agents-cloud/agent-runtime run build",
    "agent-runtime:test": "pnpm --filter @agents-cloud/agent-runtime run test",
    "agent-runtime:local": "pnpm --filter @agents-cloud/agent-runtime run local:harness",
    "agent-runtime:docker:build": "docker build -f services/agent-runtime/Dockerfile -t agents-cloud-agent-runtime:local .",
    "agent-runtime:docker:harness": "docker run --rm --entrypoint node agents-cloud-agent-runtime:local dist/src/local-runner-cli.js",
    "realtime-api:build": "pnpm --filter @agents-cloud/realtime-api run build",
    "realtime-api:test": "pnpm --filter @agents-cloud/realtime-api run test",
    "agent-creator:build": "pnpm --filter @agents-cloud/agent-creator run build",
    "agent-creator:test": "pnpm --filter @agents-cloud/agent-creator run test",
    "agent-creator:smoke": "pnpm --filter @agents-cloud/agent-creator run smoke",
    "infra:build": "pnpm control-api:build && pnpm agent-runtime:build && pnpm realtime-api:build && pnpm --filter @agents-cloud/infra-cdk run build",
    "infra:test": "pnpm --filter @agents-cloud/infra-cdk run test",
    "infra:synth": "pnpm control-api:build && pnpm agent-runtime:build && pnpm realtime-api:build && AWS_PROFILE=${AWS_PROFILE:-agents-cloud-source} AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} AGENTS_CLOUD_AWS_REGION=${AGENTS_CLOUD_AWS_REGION:-us-east-1} pnpm --filter @agents-cloud/infra-cdk run synth",
    "infra:diff": "pnpm control-api:build && pnpm agent-runtime:build && pnpm realtime-api:build && AWS_PROFILE=${AWS_PROFILE:-agents-cloud-source} AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} AGENTS_CLOUD_AWS_REGION=${AGENTS_CLOUD_AWS_REGION:-us-east-1} pnpm --filter @agents-cloud/infra-cdk run diff",
    "infra:deploy": "pnpm control-api:build && pnpm agent-runtime:build && pnpm realtime-api:build && AWS_PROFILE=${AWS_PROFILE:-agents-cloud-source} AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} AGENTS_CLOUD_AWS_REGION=${AGENTS_CLOUD_AWS_REGION:-us-east-1} pnpm --filter @agents-cloud/infra-cdk run deploy",
    "infra:bootstrap": "AWS_PROFILE=${AWS_PROFILE:-agents-cloud-source} AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} pnpm --filter @agents-cloud/infra-cdk run bootstrap",
    "amplify:sandbox": "AWS_PROFILE=${AWS_PROFILE:-agents-cloud-source} AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} pnpm --filter @agents-cloud/infra-amplify run sandbox",
    "amplify:sandbox:delete": "AWS_PROFILE=${AWS_PROFILE:-agents-cloud-source} AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} pnpm --filter @agents-cloud/infra-amplify run sandbox:delete",
    "amplify:deploy": "AWS_PROFILE=${AWS_PROFILE:-agents-cloud-source} AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} pnpm --filter @agents-cloud/infra-amplify run deploy",
    "web:dev": "pnpm --filter @agents-cloud/web dev",
    "web:typecheck": "pnpm --filter @agents-cloud/web typecheck",
    "web:test": "pnpm --filter @agents-cloud/web test",
    "web:build": "pnpm --filter @agents-cloud/web build",
    "cloudflare:build": "pnpm --filter @agents-cloud/cloudflare-realtime run build",
    "cloudflare:test": "pnpm --filter @agents-cloud/cloudflare-realtime run test",
    "cloudflare:dev": "pnpm --filter @agents-cloud/cloudflare-realtime run dev",
    "cloudflare:deploy": "pnpm --filter @agents-cloud/cloudflare-realtime run deploy",
    "cloudflare:tail": "pnpm --filter @agents-cloud/cloudflare-realtime run tail",
    "amplify:hosting:build": "pnpm web:build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
