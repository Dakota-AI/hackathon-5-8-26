{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-cloud.local/schemas/events/artifact.schema.json",
  "title": "Artifact Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifactId", "kind", "name", "uri", "contentType"],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["document", "website", "dataset", "report", "diff", "miro-board", "log", "trace", "other"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "contentType": {
      "type": "string",
      "minLength": 1
    },
    "previewUrl": {
      "type": "string",
      "format": "uri"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "bytes": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "type": "object"
    }
  }
}
