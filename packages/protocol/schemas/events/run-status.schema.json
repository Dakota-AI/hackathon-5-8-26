{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-cloud.local/schemas/events/run-status.schema.json",
  "title": "Run Status Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["runId", "status"],
  "properties": {
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "planning",
        "waiting_for_approval",
        "running",
        "testing",
        "archiving",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "message": {
      "type": "string"
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "workerClass": {
      "type": "string",
      "enum": ["agent-light", "agent-code", "agent-builder-heavy", "agent-eval", "preview-app"]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        }
      }
    }
  }
}
