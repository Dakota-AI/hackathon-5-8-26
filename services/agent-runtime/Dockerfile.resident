FROM node:22-bookworm-slim AS runtime

ENV NODE_ENV=production \
    AGENTS_RUNTIME_MODE=ecs-resident \
    AGENTS_RESIDENT_ADAPTER=smoke \
    AGENTS_RUNNER_ROOT=/runner \
    HERMES_HOME=/runner/hermes \
    HERMES_RUNNER_MODE=smoke \
    PORT=8787

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git openssh-client python3 tini \
  && rm -rf /var/lib/apt/lists/* \
  && useradd -u 10000 -m -d /runner runner \
  && mkdir -p /app /runner/workspace /runner/state /runner/artifacts /runner/profiles /runner/logs /runner/hermes \
  && chown -R runner:runner /runner /app

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY packages/protocol/package.json packages/protocol/package.json
COPY services/agent-runtime/package.json services/agent-runtime/package.json
RUN corepack enable \
  && corepack prepare pnpm@10.0.0 --activate \
  && pnpm install --filter @agents-cloud/protocol --filter @agents-cloud/agent-runtime --frozen-lockfile --prod=false

COPY packages/protocol packages/protocol
COPY services/agent-runtime services/agent-runtime
RUN pnpm --filter @agents-cloud/protocol run build \
  && pnpm --filter @agents-cloud/agent-runtime run build \
  && chown -R runner:runner /app

USER runner
WORKDIR /app/services/agent-runtime
EXPOSE 8787
ENTRYPOINT ["/usr/bin/tini", "-g", "--"]
CMD ["node", "dist/src/resident-runner-server.js"]
